# =====================================
# Server Configuration
# =====================================
SERVER_PORT=4000
SERVER_ENVIRONMENT=development
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10

# =====================================
# Database Configuration
# =====================================
DATABASE_DSN=mangosee.db

# =====================================
# Admin Bootstrap Credentials
# =====================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# =====================================
# Admin Bootstrap Credentials
# =====================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# =====================================
# Cache Configuration
# =====================================
CACHE_ENABLED=false
CACHE_ADDR=localhost:6379
CACHE_PASSWORD=
CACHE_DB=0

# =====================================
# JWT Configuration
# =====================================
JWT_ISSUER=mangosee
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=7
JWT_PRIVATE_KEY=keys/private.pem
JWT_PUBLIC_KEY=keys/public.pem

# =====================================
# Logging Configuration
# =====================================
LOGGER_BASE_PATH=./logs
LOGGER_LEVEL=debug
LOGGER_CONSOLE=true

# =====================================
# Garage S3 Configuration
# =====================================
# For local development (running 'go run' directly)
GARAGE_ENDPOINT=localhost:3900

# For Docker deployment (uncomment when running in container)
# GARAGE_ENDPOINT=garage:3900

GARAGE_ACCESS_KEY=minioadmin
GARAGE_SECRET_KEY=minioadmin
GARAGE_BUCKET=logs
GARAGE_REGION=us-east-1
GARAGE_USE_SSL=false

# =====================================
# Worker Configuration
# =====================================
WORKER_ENABLED=false
WORKER_CHECK_INTERVAL=5
WORKER_MAX_RETRIES=3
WORKER_UPLOAD_TIMEOUT=30
WORKER_S3_PREFIX=mangosee/
